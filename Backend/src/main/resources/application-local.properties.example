# Local Database Configuration Template
# COPY THIS FILE TO 'application-local.properties' AND SET YOUR LOCAL VALUES
spring.datasource.url=jdbc:mysql://localhost:3306/nexusdb?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=YOUR_MYSQL_USERNAME
spring.datasource.password=YOUR_MYSQL_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
